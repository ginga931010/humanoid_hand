<launch>

<rosparam file="$(find urdf_v2_multibody_description)/launch/controller.yaml" command="load"/>
<node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false" output="screen" ns="urdf_v2_multibody" args="Revolute 7_position_controller Revolute 8_position_controller Revolute 9_position_controller Revolute 10_position_controller Revolute 12_position_controller Revolute 13_position_controller Revolute 14_position_controller Revolute 15_position_controller Revolute 16_position_controller Revolute 17_position_controller Revolute 18_position_controller Revolute 19_position_controller Revolute 20_position_controller Revolute 21_position_controller Revolute 22_position_controller Revolute 23_position_controller Revolute 24_position_controller Revolute 25_position_controller Revolute 26_position_controller Revolute 27_position_controller Revolute 28_position_controller Revolute 29_position_controller joint_state_controller "/>
<node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="false" output="screen">
  <remap from="/joint_states" to="/urdf_v2_multibody/joint_states"/>
</node>

</launch>